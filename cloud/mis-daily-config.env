# =============================================================================
# Блок: mis-daily  |  MIS → Zoho Analytics (combined_report_temp)
# =============================================================================
# Запуск: Mac, LaunchAgent com.kravira.mis-daily, каждый день 06:30
# Скрипт: scripts/run_daily_sync.sh
# Секреты: .env (KRAVIRA_DB_PASSWORD, ZOHO_*)
# =============================================================================

# Zoho target (daily sync uses ZOHO_VIEW_ID from .env)
ZOHO_TABLE_NAME=combined_report_temp

# Mac wake before sync (scripts/setup_wake_schedule.sh)
MIS_WAKE_TIME=06:25
MIS_SYNC_TIME=06:30
