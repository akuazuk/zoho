# =============================================================================
# Блок: prognosis-sheets  |  Прогноз CF → Google Таблица «Фин_Неделя»
# =============================================================================
# Единый конфиг для Mac (локально) и GCP (Cloud Run Job).
# Секреты (Zoho tokens, JSON-ключ) — только в .env / GCP Secret Manager.
#
# Расписание (GCP): пн–пт, каждый час 08:00–17:00 по Москве
# Ручной запуск:    GitHub Actions «Run prognosis sheets» или Cloud Run → Execute
#
# После правки: git commit + push в main → Cloud Build обновит job на сервере
# =============================================================================

# Google Таблица
GOOGLE_SHEETS_ID=1KNKRinXkfECtr_UgMgv0n26viV8x4VAVSbqJKeLQ8pU
GOOGLE_SHEETS_GID=1683179599
# Лист по gid: Фин_Неделя (имя для справки, в коде используется GID)

# Куда писать суммы
# A140 — текущая неделя:
#   «Всего за неделю (факт+прогноз+страховые)» + «Сумма по Вероятности текущая неделя»
GOOGLE_SHEETS_CELL_CURRENT=A140

# A1 — следующая неделя:
#   «Прогноз на 5 дней след. недели» + «Прогноз страховые след. неделя»
#   + «Сумма по Вероятности следующая неделя»
GOOGLE_SHEETS_CELL_NEXT=A1

# Опционально: ячейка времени обновления (пусто = не писать)
# GOOGLE_SHEETS_CELL_UPDATED_AT=

# Zoho Analytics — источник
ZOHO_ORG_ID=858032450
ZOHO_WORKSPACE_ID=2929907000000004004
ZOHO_PROGNOSIS_TABLE=Прогноз_CF

# Cloud Run (не менять)
GOOGLE_SHEETS_CREDENTIALS=/secrets/sheets-sa.json
PROGNOSIS_SCHEDULE=always
